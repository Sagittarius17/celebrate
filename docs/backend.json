
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Information about a registered user of the application.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "CelebrationPage": {
      "title": "CelebrationPage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "recipientName": { "type": "string" },
        "creatorName": { "type": "string" },
        "occasion": { "type": "string" },
        "accessCode": { "type": "string" },
        "finalQuote": { "type": "string" },
        "layout": { "type": "string", "enum": ["Timeline", "Carousel", "Grid", "Collage"], "default": "Timeline" },
        "font": { "type": "string" },
        "soundtrackSource": { "type": "string", "enum": ["spotify", "youtube", "upload"], "default": "spotify" },
        "spotifyTrackId": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "customTrackDataUri": { "type": "string" },
        "spotifyTrackDurationMs": { "type": "number", "default": 180000 },
        "spotifyTrackStartMs": { "type": "number", "default": 0 },
        "spotifyLoop": { "boolean": { "type": "boolean", "default": false } },
        "voiceNoteDataUri": { "type": "string" },
        "voiceNoteDuration": { "type": "number" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "recipientName", "creatorName", "occasion", "accessCode", "ownerId", "createdAt"]
    }
  }
}
